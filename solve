#!/usr/bin/env bash
# solve — CLI shim that launches Claude Code with /solve preloaded
#
# Usage:
#   solve                              opens Claude Code, types /solve (intake prompts)
#   solve "<one-line problem>"         types /solve "<problem>"
#   solve <path/to/brief.md>           types /solve <path>
#   solve --help                       this help
#   solve --update                     re-runs the installer to refresh the skill
#   solve --uninstall                  removes the global skill, shim, and rc edits
#
# This shim runs `claude` with `/solve $@` as the first turn so the skill kicks in
# immediately. Requires Claude Code (>=2.1.32) on PATH and /solve installed
# at ~/.claude/skills/solve.

set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
  exit 0
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "ERROR: claude CLI not on PATH. Install Claude Code: https://docs.claude.com/claude-code" >&2
  exit 1
fi

SKILL="$HOME/.claude/skills/solve"
if [ ! -d "$SKILL" ] && [ "${1:-}" != "--update" ]; then
  echo "ERROR: /solve skill not installed at $SKILL" >&2
  echo "Install: bash <(curl -fsSL https://raw.githubusercontent.com/bajpainaman/solve/main/install)" >&2
  exit 1
fi

case "${1:-}" in
  update|up|--update|-u)
    if [ -d "$SKILL" ] && [ -L "$SKILL" ]; then
      SRC=$(readlink "$SKILL")
    elif [ -d "$SKILL" ]; then
      SRC="$SKILL"
    else
      SRC=""
    fi
    if [ -n "$SRC" ] && [ -x "$SRC/install" ]; then
      exec bash "$SRC/install"
    fi
    echo "Re-running remote installer..."
    exec bash <(curl -fsSL https://raw.githubusercontent.com/bajpainaman/solve/main/install)
    ;;
  uninstall|remove|--uninstall)
    set +e
    if [ -L "$SKILL" ] || [ -d "$SKILL" ]; then
      rm -rf "$SKILL"
      echo "removed $SKILL"
    fi
    SHIM="$HOME/.local/bin/solve"
    if [ -L "$SHIM" ] || [ -f "$SHIM" ]; then
      rm -f "$SHIM"
      echo "removed $SHIM"
    fi
    for rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile"; do
      if [ -f "$rc" ] && grep -q '# solve-cli >>>' "$rc" 2>/dev/null; then
        cp "$rc" "$rc.solve-bak"
        python3 - "$rc" <<'PY'
import sys, re
p = sys.argv[1]
with open(p) as f: s = f.read()
s = re.sub(r'\n?# solve-cli >>>.*?# solve-cli <<<\n?', '\n', s, flags=re.DOTALL)
with open(p, 'w') as f: f.write(s)
PY
        echo "cleaned $rc (backup at $rc.solve-bak)"
      fi
    done
    echo "Uninstalled. Note: ~/.gstack/parallel-api-key and ~/.claude/settings.json env left intact."
    exit 0
    ;;
  progress|--progress)
    # solve progress: print snapshot of the most-recent run dir under .context/solve/
    if [ ! -x "$SKILL/bin/progress" ]; then
      echo "ERROR: progress helper missing at $SKILL/bin/progress" >&2
      echo "Run: solve --update" >&2
      exit 1
    fi
    LATEST_RUN=$(ls -td .context/solve/*/ 2>/dev/null | head -1)
    if [ -z "$LATEST_RUN" ]; then
      echo "no /solve runs found in .context/solve/" >&2
      exit 1
    fi
    shift
    exec "$SKILL/bin/progress" --run-dir "${LATEST_RUN%/}" "$@"
    ;;
  calibrate|--calibrate)
    # solve calibrate <subcommand>
    if [ ! -x "$SKILL/bin/calibration" ]; then
      echo "ERROR: calibration helper missing at $SKILL/bin/calibration" >&2
      echo "Run: solve --update" >&2
      exit 1
    fi
    shift
    exec "$SKILL/bin/calibration" "$@"
    ;;
  status|--status|version|--version|-V)
    SKILL_VER=$(grep -E '^version:' "$SKILL/SKILL.md" 2>/dev/null | head -1 | awk '{print $2}')
    echo "solve CLI shim:   $0"
    echo "skill location:   $SKILL"
    if [ -L "$SKILL" ]; then echo "skill source:     $(readlink "$SKILL")"; fi
    echo "skill version:    ${SKILL_VER:-unknown}"
    echo "claude version:   $(claude --version 2>/dev/null | head -1)"
    if [ -n "${PARALLEL_API_KEY:-}" ] || [ -s "$HOME/.gstack/parallel-api-key" ]; then
      echo "parallel.ai key:  configured"
    else
      echo "parallel.ai key:  not configured (run $SKILL/bin/parallel-setup)"
    fi
    if [ "${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-}" = "1" ]; then
      echo "agent-teams flag: enabled in shell env"
    elif [ -f "$HOME/.claude/settings.json" ] && \
         python3 -c "import json,sys;d=json.load(open('$HOME/.claude/settings.json'));sys.exit(0 if d.get('env',{}).get('CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS')=='1' else 1)" 2>/dev/null; then
      echo "agent-teams flag: enabled in settings.json"
    else
      echo "agent-teams flag: NOT enabled (run solve --update)"
    fi
    exit 0
    ;;
esac

# Force agent-teams flag for the spawned claude process. The skill requires it,
# and inheriting from settings.json alone leaves a window where an already-
# running shell (which never sourced the rc) misses it. Setting it here
# guarantees /solve sees it no matter how the user got to this shim.
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# --budget flag pre-seeds Step 0.6 (budget intake) so the skill skips the
# interactive AskUserQuestion. Format: --budget time=15min tokens=$5
# Either or both can be specified. Unrecognized values are ignored.
PRESEED_ARGS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --budget)
      shift
      while [ $# -gt 0 ] && [[ "$1" =~ ^(time|tokens)= ]]; do
        case "$1" in
          time=5min|time=300)         export SOLVE_PRESEED_TIME=300; shift ;;
          time=15min|time=900)        export SOLVE_PRESEED_TIME=900; shift ;;
          time=30min|time=1800)       export SOLVE_PRESEED_TIME=1800; shift ;;
          time=1h|time=60min|time=3600) export SOLVE_PRESEED_TIME=3600; shift ;;
          time=unlimited|time=null)   export SOLVE_PRESEED_TIME=null; shift ;;
          tokens=\$1|tokens=1)        export SOLVE_PRESEED_TOKENS=1; shift ;;
          tokens=\$5|tokens=5)        export SOLVE_PRESEED_TOKENS=5; shift ;;
          tokens=\$20|tokens=20)      export SOLVE_PRESEED_TOKENS=20; shift ;;
          tokens=unlimited|tokens=null) export SOLVE_PRESEED_TOKENS=null; shift ;;
          *) shift ;;
        esac
      done
      ;;
    *)
      PRESEED_ARGS+=("$1")
      shift
      ;;
  esac
done

if [ ${#PRESEED_ARGS[@]} -eq 0 ]; then
  exec claude "/solve"
else
  exec claude "/solve ${PRESEED_ARGS[*]}"
fi
